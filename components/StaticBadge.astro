---
type Variant = 'default' | 'primary' | 'success' | 'warning' | 'error';

interface Props {
  text?: string;
  variant?: Variant;
}

const { text = 'Badge', variant = 'default' } = Astro.props;

const variantStyles: Record<Variant, { bg: string; color: string }> = {
  default: { bg: '#e0e0e0', color: '#333' },
  primary: { bg: '#3b82f6', color: '#fff' },
  success: { bg: '#10b981', color: '#fff' },
  warning: { bg: '#f59e0b', color: '#fff' },
  error: { bg: '#ef4444', color: '#fff' }
};

const style = variantStyles[variant];
---

<span
  style={{
    display: 'inline-block',
    backgroundColor: style.bg,
    color: style.color,
    padding: '0.25rem 0.75rem',
    borderRadius: '12px',
    fontSize: '0.875rem',
    fontWeight: '500',
    marginRight: '0.5rem',
    marginBottom: '0.5rem'
  }}
>
  {text}
</span>

<style>
  span {
    box-sizing: border-box;
  }
</style>
