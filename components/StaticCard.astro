---
interface Props {
  title?: string;
  description?: string;
  icon?: string;
  backgroundColor?: string;
  borderColor?: string;
}

const {
  title,
  description,
  icon,
  backgroundColor = "#f5f5f5",
  borderColor = "#e0e0e0"
} = Astro.props;
---

<div
  style={{
    backgroundColor,
    border: `1px solid ${borderColor}`,
    borderRadius: '8px',
    padding: '1.5rem',
    marginBottom: '1rem'
  }}
>
  {icon && <div style={{ fontSize: '2rem', marginBottom: '0.5rem' }}>{icon}</div>}
  {title && <h3 style={{ margin: '0.5rem 0', fontSize: '1.25rem' }}>{title}</h3>}
  {description && <p style={{ margin: '0.5rem 0', color: '#666' }}>{description}</p>}
</div>

<style>
  div {
    box-sizing: border-box;
  }
</style>
