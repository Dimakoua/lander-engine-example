---
interface Props {
  color?: string;
  thickness?: number;
  margin?: string;
}

const { color = '#e0e0e0', thickness = 1, margin = '2rem 0' } = Astro.props;
---

<hr
  style={{
    border: 'none',
    height: `${thickness}px`,
    backgroundColor: color,
    margin
  }}
/>

<style>
  hr {
    box-sizing: border-box;
  }
</style>
